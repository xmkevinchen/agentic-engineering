{
  "name": "ae",
  "version": "0.7.0",
  "description": "Agentic Engineering workflow for Claude Code. Multi-agent TDD, cross-family review (Claude + Codex + Gemini), structured planning and analysis.",
  "author": {
    "name": "ckai"
  },
  "repository": "https://github.com/xmkevinchen/agentic-engineering",
  "license": "MIT",
  "keywords": [
    "agentic-engineering",
    "tdd",
    "code-review",
    "cross-family",
    "multi-agent",
    "workflow-automation",
    "agent-teams"
  ],
  "userConfig": {
    "gemini_flash_model": {
      "title": "Gemini Flash Model",
      "description": "Gemini Flash model name",
      "type": "string",
      "default": "gemini-2.5-flash"
    },
    "gemini_pro_model": {
      "title": "Gemini Pro Model",
      "description": "Gemini Pro model name",
      "type": "string",
      "default": "gemini-2.5-pro"
    }
  },
  "outputStyles": [
    "./output-styles/ae-structured.md",
    "./output-styles/ae-compact.md"
  ],
  "mcpServers": {
    "codex": {
      "command": "codex",
      "args": ["mcp-server"]
    },
    "gemini": {
      "command": "bash",
      "args": ["-c", "cd \"${CLAUDE_PLUGIN_ROOT}/mcp-servers/gemini\" && npm install --omit=dev --silent >&2 && exec node dist/index.js"],
      "env": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY}"
      }
    }
  }
}
